---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Container, Icon } from '../react/primitives.jsx';

// Astro build → /404.html. Cloudflare Pages tự phục vụ file này với HTTP 404
// cho mọi URL không khớp. noindex để công cụ tìm kiếm không lập chỉ mục.
---

<BaseLayout
  title="Không tìm thấy trang (404)"
  description="Trang bạn tìm không tồn tại hoặc đã được di chuyển."
  noindex={true}
  canonical="https://nhlegal.com.vn/404"
>
  <main>
    <div style="background:linear-gradient(135deg,#063E45 0%,#0A5258 55%,#0D6470 100%);padding:clamp(96px,16vw,160px) 0 clamp(72px,12vw,120px);text-align:center">
      <Container narrow>
        <div style="font-family:var(--font-display);font-weight:600;font-size:clamp(72px,16vw,140px);line-height:1;color:rgba(255,255,255,0.92)">404</div>
        <h1 style="font-family:var(--font-display);font-weight:500;font-size:clamp(24px,4vw,38px);color:#FFFFFF;margin:16px 0 0">Không tìm thấy trang</h1>
        <p style="max-width:480px;margin:16px auto 0;font-size:16px;line-height:1.7;color:rgba(255,255,255,0.65);font-family:var(--font-sans)">
          Trang bạn tìm không tồn tại hoặc đã được di chuyển. Bạn có thể quay về trang chủ hoặc xem các dịch vụ của chúng tôi.
        </p>
        <div style="margin-top:36px;display:flex;gap:14px;flex-wrap:wrap;justify-content:center">
          <a href="/" class="nh-btn nh-btn-primary" style="background:linear-gradient(180deg,#DCC089 0%,#BE9F61 50%,#A4853F 100%);color:#FFFFFF;text-shadow:0 1px 1.5px rgba(96,74,30,0.55)">
            <span>Về trang chủ</span><span class="nh-btn-ar"><Icon name="arrow-right" size={16} stroke={2} /></span>
          </a>
          <a href="/dich-vu" class="nh-cta-phone"><Icon name="list-checks" size={15} stroke={2} /> Xem dịch vụ</a>
        </div>
      </Container>
    </div>
  </main>
</BaseLayout>

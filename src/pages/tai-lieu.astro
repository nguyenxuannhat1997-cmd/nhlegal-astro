---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Container, Icon } from '../react/primitives.jsx';

const SITE = 'https://nhlegal.com.vn';
const url = `${SITE}/tai-lieu`;

// Biểu mẫu — file thật chưa sẵn sàng (fileUrl null). Nút → liên hệ nhận biểu mẫu.
// Render TĨNH (zero-JS). Khi có file: đặt vào public/tai-lieu/ + cập nhật href.
const TEMPLATES = [
  { icon: 'heart-crack', cat: 'Hôn nhân & Gia đình', title: 'Đơn thuận tình ly hôn', desc: 'Mẫu đơn yêu cầu công nhận thuận tình ly hôn kèm hướng dẫn điền.' },
  { icon: 'scroll',      cat: 'Hợp đồng & Giao dịch', title: 'Hợp đồng đặt cọc mua bán nhà đất', desc: 'Mẫu hợp đồng đặt cọc an toàn, có điều khoản bảo vệ bên mua.' },
  { icon: 'briefcase',   cat: 'Doanh nghiệp & Đầu tư', title: 'Biên bản họp Hội đồng thành viên', desc: 'Mẫu biên bản họp Hội đồng thành viên công ty TNHH.' },
  { icon: 'users',       cat: 'Lao động & Nhân sự', title: 'Hợp đồng lao động', desc: 'Mẫu hợp đồng lao động chuẩn cho doanh nghiệp.' },
  { icon: 'building-2',  cat: 'Đất đai & Nhà ở', title: 'Giấy ủy quyền', desc: 'Mẫu giấy ủy quyền cá nhân dùng trong giao dịch nhà đất.' },
  { icon: 'scale',       cat: 'Tố tụng', title: 'Đơn khởi kiện dân sự', desc: 'Mẫu đơn khởi kiện gửi Tòa án nhân dân có thẩm quyền.' },
];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Trang chủ', item: `${SITE}/` },
    { '@type': 'ListItem', position: 2, name: 'Tài liệu', item: url },
  ],
};
---

<BaseLayout
  title="Tài liệu & Biểu mẫu pháp lý"
  description="Bộ biểu mẫu pháp lý thường dùng do đội ngũ luật sư N.H Legal biên soạn theo pháp luật Việt Nam: hợp đồng, đơn từ, biên bản. Liên hệ để nhận biểu mẫu."
  canonical={url}
  jsonLd={[breadcrumb]}
>
  <main>
    <div style="background:linear-gradient(135deg,#063E45 0%,#0A5258 55%,#0D6470 100%);padding:clamp(64px,10vw,100px) 0 clamp(48px,7vw,72px)">
      <Container>
        <a href="/" class="nh-foot-contact-link" style="display:inline-flex;align-items:center;gap:8px;color:rgba(255,255,255,0.55);font-size:13px;font-family:var(--font-sans);margin-bottom:28px">
          <Icon name="arrow-left" size={14} stroke={2} /> Trang chủ
        </a>
        <div style="font-size:12px;letter-spacing:0.18em;text-transform:uppercase;color:rgba(255,255,255,0.4);font-family:var(--font-sans);margin-bottom:16px">Tài nguyên pháp lý</div>
        <h1 style="font-family:var(--font-display);font-weight:500;font-size:clamp(32px,5vw,56px);letter-spacing:-0.02em;color:#FFFFFF;margin:0;line-height:1.1">Tài liệu &amp; Biểu mẫu</h1>
        <p style="max-width:600px;margin:18px 0 0;font-size:16px;line-height:1.7;color:rgba(255,255,255,0.6);font-family:var(--font-sans)">
          Bộ biểu mẫu pháp lý thường dùng, biên soạn theo pháp luật Việt Nam hiện hành. Liên hệ để nhận tài liệu.
        </p>
      </Container>
    </div>

    <div style="background:#FAFAFA;padding:clamp(40px,6vw,72px) 0 clamp(64px,10vw,100px)">
      <Container>
        <div class="nh-blog-grid">
          {TEMPLATES.map((t) => (
            <div class="nh-doc-card" style="display:flex;flex-direction:column;padding:28px;background:#FFFFFF;border:1.5px solid var(--nh-line);border-radius:18px;box-shadow:var(--shadow-1)">
              <span style="width:48px;height:48px;border-radius:12px;background:var(--nh-teal-50);color:var(--nh-teal-700);display:inline-flex;align-items:center;justify-content:center;margin-bottom:18px">
                <Icon name={t.icon} size={22} stroke={1.5} />
              </span>
              <div style="font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--nh-teal-700);font-weight:600">{t.cat}</div>
              <h2 style="margin:8px 0 0;font-family:var(--font-display);font-weight:500;font-size:20px;line-height:1.3;color:var(--nh-navy-900)">{t.title}</h2>
              <p style="margin:10px 0 20px;font-size:14px;line-height:1.6;color:var(--fg-2);flex:1;text-align:left">{t.desc}</p>
              <a href="/#contact" class="nh-doc-cta" style="align-self:flex-start;display:inline-flex;align-items:center;gap:8px;padding:10px 18px;background:transparent;color:var(--nh-teal-700);border:1.5px solid var(--nh-teal-700);border-radius:999px;font-family:var(--font-sans);font-weight:600;font-size:13.5px;text-decoration:none">
                Liên hệ nhận biểu mẫu <Icon name="arrow-right" size={14} stroke={2} />
              </a>
            </div>
          ))}
        </div>
        <p style="margin:36px auto 0;max-width:620px;font-size:13px;color:var(--fg-mute);text-align:center;line-height:1.6">
          Biểu mẫu chỉ mang tính tham khảo, không thay thế tư vấn pháp lý cho từng trường hợp cụ thể. Cần hỗ trợ soạn thảo riêng? <a href="/#contact" style="color:var(--nh-teal-700);text-decoration:underline">Liên hệ luật sư</a>.
        </p>
      </Container>
    </div>
  </main>
</BaseLayout>
